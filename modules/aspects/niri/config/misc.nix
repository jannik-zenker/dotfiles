{
  den.aspects.niri = {
    homeManager = {
      programs.niri.settings = {
        hotkey-overlay = {
          skip-at-startup = true;
          hide-not-bound = true;
        };
        prefer-no-csd = true;
        screenshot-path = "~/Pictures/Screenshots/scrsh_%Y-%m-%d %H-%M-%S.png";
        clipboard.disable-primary = true;
      };
    };
  };
}
